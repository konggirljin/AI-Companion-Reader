{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],

  "agent": {
    "general": {
      "description": "Implements plan tasks, runs tests, fixes code per plan instructions",
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5"
      "task": true
    },
    "explore": {
      "description": "Explores codebase — file search, read, grep. No edits",
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5"
       "task": true
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/glm-5.2",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
